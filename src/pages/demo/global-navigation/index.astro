---
import ContentsLayout from "@layouts/ContentsLayout.astro";
import { Button } from "@components/index.tsx";

export const frontmatter: Frontmatter = {
  title: "グローバルナビゲーションデモ",
  description: "モバイルデバイス向けのグローバルナビゲーション機能を提供するJavaScriptクラス。ボタンクリックでナビゲーションの開閉、ESCキーでのクローズ、リサイズ時の自動クローズ、フォーカストラップなどをサポートします。",
};
---

<ContentsLayout frontmatter={frontmatter}>
  <article class="html-contents">
    <h1 class="p-contents-title">{frontmatter.title}</h1>

    <div class="demo-area">
      <ul class="demo-gnav-buttons">
        <li class="demo-gnav_item">
          <Button className="js-demoOpenBtn" aria-label="デモナビゲーション1" aria-controls="demo-gnav-1" aria-expanded="false">メニュー1</Button>
          <nav id="demo-gnav-1" class="demo-gnav" aria-hidden="true">
            <h2>メニュー1の内容</h2>
            <ul>
              <li><a class="js-gnav-start" href="#demo1-1">メニュー1 - リンク1</a></li>
              <li><a href="#demo1-2">メニュー1 - リンク2</a></li>
              <li><a href="#demo1-3">メニュー1 - リンク3</a></li>
            </ul>
            <Button className="demo-gnav_close js-demoCloseBtn js-gnav-end" aria-label="ナビゲーションを閉じる">×</Button>
          </nav>
        </li>

        <li class="demo-gnav_item">
          <Button className="js-demoOpenBtn" aria-label="デモナビゲーション2" aria-controls="demo-gnav-2" aria-expanded="false">メニュー2</Button>
          <nav id="demo-gnav-2" class="demo-gnav" aria-hidden="true">
            <h2>メニュー2の内容</h2>
            <ul>
              <li><a class="js-gnav-start" href="#demo2-1">メニュー2 - リンク1</a></li>
              <li><a href="#demo2-2">メニュー2 - リンク2</a></li>
              <li><a href="#demo2-3">メニュー2 - リンク3</a></li>
            </ul>
            <Button className="demo-gnav_close js-demoCloseBtn js-gnav-end" aria-label="ナビゲーションを閉じる">×</Button>
          </nav>
        </li>

        <li class="demo-gnav_item">
          <Button className="js-demoOpenBtn" aria-label="デモナビゲーション3" aria-controls="demo-gnav-3" aria-expanded="false">メニュー3</Button>
          <nav id="demo-gnav-3" class="demo-gnav" aria-hidden="true">
            <h2>メニュー3の内容</h2>
            <ul>
              <li><a class="js-gnav-start" href="#demo3-1">メニュー3 - リンク1</a></li>
              <li><a href="#demo3-2">メニュー3 - リンク2</a></li>
              <li><a href="#demo3-3">メニュー3 - リンク3</a></li>
            </ul>
            <Button className="demo-gnav_close js-demoCloseBtn js-gnav-end" aria-label="ナビゲーションを閉じる">×</Button>
          </nav>
        </li>

        <li class="demo-gnav_item">
          <Button className="js-demoOpenBtn" aria-label="デモナビゲーション4" aria-controls="demo-gnav-4" aria-expanded="false">メニュー4</Button>
          <nav id="demo-gnav-4" class="demo-gnav" aria-hidden="true">
            <h2>メニュー4の内容</h2>
            <ul>
              <li><a class="js-gnav-start" href="#demo4-1">メニュー4 - リンク1</a></li>
              <li><a href="#demo4-2">メニュー4 - リンク2</a></li>
              <li><a href="#demo4-3">メニュー4 - リンク3</a></li>
            </ul>
            <Button className="demo-gnav_close js-demoCloseBtn js-gnav-end" aria-label="ナビゲーションを閉じる">×</Button>
          </nav>
        </li>
      </ul>

      <div class="demo-backdrop js-demoBackdrop" aria-hidden="true"></div>
    </div>
  </article>

  <Fragment slot="end-head">
    <meta name="robots" content="noindex,nofollow" />
  </Fragment>
</ContentsLayout>

<script>
  import GlobalNavigation from "@src/stories/assets/js/modules/TSGlobalNavigation.ts";
  import Backdrop from "@src/stories/assets/js/modules/Backdrop.ts";

  // 複数ボタン対応のデモ用GlobalNavigation（本物とは別のセレクタを使用）
  new GlobalNavigation({
    button: ".js-demoOpenBtn",
    navigation: ".demo-gnav", // 複数のナビゲーション要素をまとめて指定
    closeButton: ".js-demoCloseBtn",
    closeOnResize: true,
    activeClass: "is-active",
    focusTrap: [".js-gnav-start", ".js-gnav-end"],
  });

  // デモ用のBackdrop
  new Backdrop({
    button: ".js-demoOpenBtn",
    backdrop: ".js-demoBackdrop",
    closeButton: ".js-demoCloseBtn",
    excludeClose: [".demo-gnav"], // 複数のナビゲーション要素を除外
    closeOnResize: true,
  });
</script>
