<ol id="progress-list" class="p-progress_list -depth-1">
  <!-- The table of contents will be generated by JavaScript -->
</ol>

<script>
  import { generateInternalLink } from "@src/assets/js/main.ts";

  // Define types for headings
  type H3Item = {
    element: Element;
    heading: string | null;
    id: string;
  };

  type H2Item = {
    element: Element;
    heading: string | null;
    id: string;
    h3: H3Item[];
  };

  type HeadingPosition = {
    type: "h2" | "h3";
    element: Element;
    h2Index: number;
    h3Index: number | null;
    position: number;
  };

  /**
   * 見出し要素にIDを付与する
   * @param heading 見出し要素
   */
  function addIdToHeading(heading: Element): void {
    const headingText = heading.textContent || "";
    heading.id = generateInternalLink(headingText);
  }

  /**
   * 見出しがH2レベルかどうかを判定する
   * @param heading 見出し要素
   * @returns H2レベルかどうか
   */
  function isH2Level(heading: Element): boolean {
    return heading.classList.contains("p-heading-lv2") || (heading.tagName.toLowerCase() === "h2" && heading.closest(".markdown-contents"));
  }

  /**
   * 見出しがH3レベルかどうかを判定する
   * @param heading 見出し要素
   * @returns H3レベルかどうか
   */
  function isH3Level(heading: Element): boolean {
    return heading.classList.contains("p-heading-lv3") || (heading.tagName.toLowerCase() === "h3" && heading.closest(".markdown-contents"));
  }

  /**
   * 見出し構造を構築する
   * @param headings 見出し要素のリスト
   * @returns 構造化された見出しデータ
   */
  function buildHeadingStructure(headings: NodeListOf<Element>): H2Item[] {
    const structure: H2Item[] = [];
    let currentH2: H2Item | null = null;

    headings.forEach((heading) => {
      if (isH2Level(heading)) {
        // H2見出しの処理
        currentH2 = {
          element: heading,
          heading: heading.textContent,
          id: heading.id,
          h3: [],
        };
        structure.push(currentH2);
      } else if (isH3Level(heading) && currentH2) {
        // H3見出しの処理（親H2がある場合）
        currentH2.h3.push({
          element: heading,
          heading: heading.textContent,
          id: heading.id,
        });
      }
    });

    return structure;
  }

  /**
   * 目次のHTMLを生成する
   * @param structure 構造化された見出しデータ
   * @returns HTML文字列
   */
  function generateTableOfContents(structure: H2Item[]): string {
    return structure
      .map((h2Item) => {
        // H3項目の生成
        const h3Items = h2Item.h3.length > 0 ? `<ol class="p-progress_list -depth-2">${h2Item.h3.map((h3Item) => `<li><a href="#${h3Item.id}">${h3Item.heading || ""}</a></li>`).join("")}</ol>` : "";

        // H2項目の生成（子のH3項目を含む）
        return `<li><a href="#${h2Item.id}">${h2Item.heading || ""}</a>${h3Items}</li>`;
      })
      .join("");
  }

  /**
   * ページスクロールに連動して目次をスクロールする
   * @param progressList 目次要素
   */
  function syncProgressScroll(progressList: HTMLElement): void {
    const progressInner = progressList.closest(".p-progress_inner") as HTMLElement;
    if (!progressInner) return;

    // ページ全体の情報を取得
    const documentHeight = document.documentElement.scrollHeight;
    const windowHeight = window.innerHeight;
    const scrollTop = window.scrollY;

    // ページスクロールの進行率を計算（0〜1）
    const maxPageScroll = documentHeight - windowHeight;
    const pageScrollRatio = maxPageScroll > 0 ? scrollTop / maxPageScroll : 0;

    // 目次のスクロール位置を進行率に基づいて計算
    const maxProgressScroll = progressInner.scrollHeight - progressInner.clientHeight;
    const targetScrollTop = pageScrollRatio * maxProgressScroll;

    // 目次をスクロール（最下部なら確実に最下部へ）
    progressInner.scrollTop = pageScrollRatio >= 0.99 ? maxProgressScroll : targetScrollTop;
  }

  /**
   * スクロール位置に基づいて現在アクティブな見出しを更新する
   * @param progressList 目次要素
   * @param structure 見出し構造
   */
  function updateActiveHeading(progressList: HTMLElement, structure: H2Item[]): void {
    const scrollPosition = window.scrollY;

    // 目次スクロールを同期
    syncProgressScroll(progressList);

    // すべてのアクティブクラスを解除
    document.querySelectorAll("#progress-list li").forEach((li) => {
      li.classList.remove("is-active");
    });

    // ページ最上部の場合、最初の項目をアクティブに
    if (scrollPosition <= 100) {
      const firstLi = progressList.querySelector(":scope > li");
      if (firstLi) {
        firstLi.classList.add("is-active");
        return;
      }
    }

    // 見出し位置データの作成
    const allHeadings: HeadingPosition[] = [];

    // すべての見出し位置を収集
    structure.forEach((h2Item, h2Index) => {
      // H2見出しを追加
      allHeadings.push({
        type: "h2",
        element: h2Item.element,
        h2Index: h2Index,
        h3Index: null,
        position: (h2Item.element as HTMLElement).offsetTop,
      });

      // H3見出しを追加
      h2Item.h3.forEach((h3Item, h3Index) => {
        allHeadings.push({
          type: "h3",
          element: h3Item.element,
          h2Index: h2Index,
          h3Index: h3Index,
          position: (h3Item.element as HTMLElement).offsetTop,
        });
      });
    });

    // 上から下への位置順に並べ替え
    allHeadings.sort((a, b) => a.position - b.position);

    // 現在のスクロール位置に最も近い見出しを探す
    for (let i = allHeadings.length - 1; i >= 0; i--) {
      const heading = allHeadings[i];
      if (heading.position <= scrollPosition) {
        const h2Items = progressList.children;

        if (heading.type === "h2") {
          // H2の場合、対応する項目をアクティブに
          const h2Item = h2Items[heading.h2Index];
          if (h2Item) {
            h2Item.classList.add("is-active");
          }
        } else {
          // H3の場合、対応するH3項目をアクティブに
          const h2Item = h2Items[heading.h2Index];
          if (!h2Item) continue;

          const h3List = h2Item.querySelector("ol");
          if (!h3List) continue;

          const h3Item = h3List.children[heading.h3Index as number];
          if (h3Item) {
            h3Item.classList.add("is-active");
          }
        }
        break;
      }
    }
  }

  // メイン処理
  function initProgressContents(): void {
    // 見出し要素の取得
    const headings = document.querySelectorAll('.p-heading-lv2:not([data-progress="false"]), .p-heading-lv3:not([data-progress="false"]), .p-heading-lv4:not([data-progress="false"]), .markdown-contents h2:not([data-progress="false"]), .markdown-contents h3:not([data-progress="false"]), .markdown-contents h4:not([data-progress="false"])');

    // 見出しにIDを追加
    headings.forEach(addIdToHeading);

    // 見出し構造の構築
    const structure = buildHeadingStructure(headings);

    // 目次要素の取得
    const progressList = document.getElementById("progress-list");
    if (!progressList || structure.length === 0) return;

    // 目次HTMLの生成と挿入
    progressList.innerHTML = generateTableOfContents(structure);

    // スクロールイベントリスナーの設定
    const handleScroll = () => updateActiveHeading(progressList, structure);
    window.addEventListener("scroll", handleScroll);
    window.addEventListener("resize", handleScroll);

    // 初期状態の設定（ページ読み込み時）
    handleScroll();
  }

  // 初期化の実行
  initProgressContents();
</script>
