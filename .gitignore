# Visual regression testing (Vitest)
# Vitest default structure:
# __screenshots__/*/  - baseline images in subdirs (committed to git)
# .vitest-attachments/  - actual/diff images (ignored)
# Flat files in __screenshots__/  - failure screenshots (ignored)
.vitest-attachments/
**/__screenshots__/*.vrt.test.ts/*.png

# claude
.claude/settings.local.json

# internal notes
note/
.vercel
.env*.local
