{
  "name": "astro-project",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "build:only": "astro build",
    "build:compress": "svgo -rf dist && npm run compress",
    "build:all": "npm run build && npm run build-storybook",
    "preview": "astro preview",
    "astro": "astro",
    "compress": "node utils/image-compression/src/ImageCompression.js",
    "test": "vitest --pool=forks",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:unit:watch": "vitest --config vitest.config.unit.ts",
    "vrt": "vitest",
    "vrt:ui": "vitest --ui",
    "vrt:update": "vitest run -u",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o dist/_styleguide",
    "e2e": "npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "axe": "npx playwright test axe.test --reporter=list",
    "nu": "npx playwright test nu.test --workers=2 --reporter=list"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.6",
    "@astrojs/react": "^4.4.1",
    "@astrojs/sitemap": "^3.6.1",
    "@astrojs/tailwind": "^6.0.2",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@fontsource/big-shoulders-stencil": "^5.2.6",
    "@twemoji/api": "^16.0.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vercel/edge": "^1.2.2",
    "bootstrap": "^5.3.8",
    "browserslist": "^4.26.3",
    "clsx": "^2.1.1",
    "gsap": "^3.13.0",
    "purgecss": "^7.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-external-links": "^3.0.0",
    "rimraf": "^6.1.2",
    "scroll-hint": "^1.2.9",
    "sitemapper": "^4.0.2",
    "tailwindcss": "^3.4.18",
    "twemoji": "^14.0.2",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@biomejs/biome": "2.4.9",
    "@chromatic-com/storybook": "^4.1.2",
    "@eslint/js": "^9.37.0",
    "@eslint/json": "^0.13.2",
    "@html-eslint/eslint-plugin": "^0.47.0",
    "@html-eslint/parser": "^0.47.0",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-onboarding": "^10.1.11",
    "@storybook/addon-vitest": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@tailwindcss/container-queries": "^0.1.1",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^25.0.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser": "^4.0.16",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "astro": "^5.14.1",
    "autoprefixer": "^10.4.19",
    "axe-html-reporter": "^2.2.11",
    "eslint": "^9.37.0",
    "eslint-plugin-storybook": "^10.1.11",
